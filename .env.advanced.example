# Advanced template.
# Copy this file to a local .env and replace placeholder values as needed.
# Do not commit real API keys.

# ------------------------------
# Base paths
# ------------------------------
CODEX_MEMORY_BASE_PATH=A:\codex-memory
CODEX_MEMORY_DATA_DIR=data
CODEX_MEMORY_LOGS_DIR=logs
CODEX_MEMORY_DIARY_PATH=data/dailynote

# ------------------------------
# HTTP MCP runtime
# ------------------------------
CODEX_MEMORY_HTTP_HOST=127.0.0.1
CODEX_MEMORY_HTTP_PORT=7605
CODEX_MEMORY_HTTP_PATH=/mcp/codex-memory
# CODEX_MEMORY_HTTP_TOKEN=replace-with-a-secure-random-string
# Without a bearer token, search_memory / record_memory / memory_overview are rejected on HTTP.

# ------------------------------
# Search / indexing defaults
# ------------------------------
CODEX_MEMORY_EMBED_DIMS=1024
CODEX_MEMORY_EMBEDDING_PROFILE_VERSION=v1
CODEX_MEMORY_RAG_PARAMS_PATH=examples/rag-params.profiles.example.json
CODEX_MEMORY_MAX_SEARCH_LIMIT=10
CODEX_MEMORY_DEFAULT_SEARCH_LIMIT=5
CODEX_MEMORY_ENABLE_EMBEDDING_CACHE=true
CODEX_MEMORY_ENABLE_CANDIDATE_CACHE=true
CODEX_MEMORY_AUTO_REBUILD=false
CODEX_MEMORY_AUTO_REBUILD_ACTIVE_MEMORY=false

# ------------------------------
# ------------------------------
# Security profile
# Allowed: local (default), hardened
# hardened enables soft/lifecycle/write-preflight policies and blocks external providers.
# Explicit env vars override profile defaults.
# ------------------------------
# CODEX_MEMORY_SECURITY_PROFILE=hardened

# ------------------------------
# External provider gate
# When false (default), embedding/rerank never fetch external endpoints.
# Set to true only when you intentionally use remote embedding/rerank.
# ------------------------------
# CODEX_MEMORY_ALLOW_EXTERNAL_PROVIDER=false

# ------------------------------
# Primary embedding chain
# 1) local bge-m3-local
# 2) fallback remote provider (for example NVIDIA)
# 3) local-hash final fallback inside codex-memory
# ------------------------------
CODEX_MEMORY_LOCAL_EMBEDDING_PROVIDER=bge-m3-local
CODEX_MEMORY_LOCAL_EMBEDDING_URL=http://127.0.0.1:18081/
CODEX_MEMORY_LOCAL_EMBEDDING_MODEL=bge-m3-local
# CODEX_MEMORY_LOCAL_EMBEDDING_API_KEY=replace-me
# CODEX_MEMORY_LOCAL_EMBEDDING_PATH=v1/embeddings

CODEX_MEMORY_FALLBACK_EMBEDDING_PROVIDER=nvidia
CODEX_MEMORY_FALLBACK_EMBEDDING_URL=https://integrate.api.nvidia.com/
CODEX_MEMORY_FALLBACK_EMBEDDING_API_KEY=replace-me
CODEX_MEMORY_FALLBACK_EMBEDDING_MODEL=baai/bge-m3
# CODEX_MEMORY_FALLBACK_EMBEDDING_HEADERS_JSON={"x-tenant":"demo"}

# Legacy-compatible environment names also work when they are already exported:
# EMBEDDING_API_URL=http://127.0.0.1:18081
# EMBEDDING_FALLBACK_API_URL=https://integrate.api.nvidia.com
# EMBEDDING_FALLBACK_API_KEY=replace-me
# EMBEDDING_FALLBACK_MODEL=baai/bge-m3

# ------------------------------
# Rerank provider
# Supported providers: cohere, voyage, jina, generic
# ------------------------------
CODEX_MEMORY_RERANK_PROVIDER=jina
CODEX_MEMORY_RERANK_URL=https://api.jina.ai/
CODEX_MEMORY_RERANK_API_KEY=replace-me
CODEX_MEMORY_RERANK_MODEL=jina-reranker-v2-base-multilingual
# CODEX_MEMORY_RERANK_PATH=v1/rerank
# CODEX_MEMORY_RERANK_HEADERS_JSON={"x-tenant":"demo"}

# ------------------------------
# LightMemo directory policy
# excluded folders are removed at candidate stage
# directory map lets logical folder names resolve to real path segments
# ------------------------------
CODEX_MEMORY_LIGHTMEMO_EXCLUDED_FOLDERS=ArchiveKB,MusicDiary
CODEX_MEMORY_LIGHTMEMO_DIRECTORY_MAP_JSON={"keke":["Keke"],"studioalpha":["TeamShared","ProjectAlpha"],"studiobeta":["TeamShared","ProjectBeta"],"public":{"any":["PublicKB","SharedKB"]}}

# ------------------------------
# Active memory donor root for Phase C rebuilds
# ------------------------------
CODEX_MEMORY_ACTIVE_MEMORY_ROOT=
# Minimum interval for donor incremental sync checks.
# Set to 0 during tests or active debugging.
CODEX_MEMORY_ACTIVE_MEMORY_SYNC_MIN_INTERVAL_MS=5000
# Donor-style blocked keywords for DeepMemo.
# Comma-separated. Blocked terms are filtered before search.
# If every keyword is blocked, DeepMemo will reject the query.
CODEX_MEMORY_ACTIVE_BLOCKED_KEYWORDS=
# Optional donor-style DeepMemo rerank.
# When true, DeepMemo will try remote rerank if a rerank provider is configured.
# If rerank fails, codex-memory will fall back to the original active-memory results.
CODEX_MEMORY_ACTIVE_RERANK_SEARCH=false
