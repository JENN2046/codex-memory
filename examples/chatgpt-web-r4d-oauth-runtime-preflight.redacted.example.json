    "scopes": ["memory.read"],
    "pkce_method": "S256",
    "token_endpoint_auth_method": "none",
    "resource_parameter_on_authorization": true,
    "resource_parameter_on_token": true,
    "audience_claim_required": true,
    "anonymous_access": false
  },
  "endpoints": {
    "public_origin": "https://edge.example.invalid",
    "mcp_path": "/mcp",
