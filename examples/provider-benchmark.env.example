# Copy this file to a local .env or export the variables directly before running:
#   npm run provider-benchmark -- --providers local,bge-m3-local,cohere,voyage,jina --json

# Optional local baseline settings
CODEX_MEMORY_BENCH_LOCAL_EMBED_DIMS=64

# ------------------------------
# Local bge-m3 embedding benchmark
# ------------------------------
CODEX_MEMORY_BENCH_BGE_M3_LOCAL_EMBEDDING_URL=http://127.0.0.1:18081/
CODEX_MEMORY_BENCH_BGE_M3_LOCAL_EMBEDDING_MODEL=bge-m3-local
# Optional override if your local service uses another route
# CODEX_MEMORY_BENCH_BGE_M3_LOCAL_EMBEDDING_PATH=v1/embeddings

# Optional dataset override
# CODEX_MEMORY_BENCH_DATASET=A:\codex-memory\benchmarks\default-dataset.json

# ------------------------------
# Cohere embedding benchmark
# ------------------------------
CODEX_MEMORY_BENCH_COHERE_EMBEDDING_URL=https://api.cohere.com/
CODEX_MEMORY_BENCH_COHERE_EMBEDDING_API_KEY=replace-me
CODEX_MEMORY_BENCH_COHERE_EMBEDDING_MODEL=embed-v4.0

# ------------------------------
# Voyage embedding benchmark
# ------------------------------
CODEX_MEMORY_BENCH_VOYAGE_EMBEDDING_URL=https://api.voyageai.com/
CODEX_MEMORY_BENCH_VOYAGE_EMBEDDING_API_KEY=replace-me
CODEX_MEMORY_BENCH_VOYAGE_EMBEDDING_MODEL=voyage-4-large

# ------------------------------
# Jina embedding benchmark
# ------------------------------
CODEX_MEMORY_BENCH_JINA_EMBEDDING_URL=https://api.jina.ai/
CODEX_MEMORY_BENCH_JINA_EMBEDDING_API_KEY=replace-me
CODEX_MEMORY_BENCH_JINA_EMBEDDING_MODEL=jina-embeddings-v4

# Optional provider-specific overrides
# CODEX_MEMORY_BENCH_COHERE_EMBED_DIMS=1536
# CODEX_MEMORY_BENCH_VOYAGE_EMBED_DIMS=1024
# CODEX_MEMORY_BENCH_JINA_EMBED_DIMS=1024
# CODEX_MEMORY_BENCH_JINA_EMBEDDING_TIMEOUT_MS=20000
