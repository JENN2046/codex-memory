    {
      "id": "tag-title-body-evidence-order",
      "description": "TagMemo plus rerank should prefer tag+title and title-only matches over lower-confidence body/evidence records without overfitting tiny tail-score deltas.",
      "target": "process",
      "query": "[[orm migration checkpoint]] ::TagMemo+1.8 ::Rerank+0.6",
      "limit": 4,
      "records": [
        {
          "date": "2026-04-19T09:00:00.000Z",
          "title": "ORM migration lens",
          "memoryId": "p16-tag-title",
          "content": "adapter notes with rollback details",
          "evidence": "tag and title weighted hit",
          "tags": [
            "orm",
            "migration"
          ]
        },
        {
          "date": "2026-04-19T09:05:00.000Z",
          "title": "ORM migration headline",
          "memoryId": "p16-title-only",
          "content": "refactor notes without explicit tags",
          "evidence": "title weighted hit",
          "tags": []
        },
        {
          "date": "2026-04-19T09:10:00.000Z",
          "title": "General notebook",
          "memoryId": "p16-body-only",
          "content": "orm migration checkpoint appears only inside body text",
          "evidence": "body weighted hit",
          "tags": []
        },
        {
          "date": "2026-04-19T09:15:00.000Z",
          "title": "Evidence notebook",
          "memoryId": "p16-evidence-only",
          "content": "adapter notes",
          "evidence": "orm migration checkpoint appears only in evidence text",
          "tags": []
        }
      ],
      "expected": {
        "memoryIds": [
          "p16-tag-title",
          "p16-title-only",
          "p16-evidence-only",
          "p16-body-only"
        ],
        "orderContract": {
          "topPrefix": [
            "p16-tag-title",
            "p16-title-only"
          ],
          "remainingSetAfterPrefix": [
            "p16-body-only",
            "p16-evidence-only"
          ],
          "containsExactly": [
            "p16-tag-title",
            "p16-title-only",
            "p16-body-only",
            "p16-evidence-only"
          ]
        },
        "matchedTagsByMemoryId": {
          "p16-tag-title": [
            "orm",
            "migration"
          ],
          "p16-title-only": [],
          "p16-body-only": [],
          "p16-evidence-only": []
        },
        "audit": {
          "target": "process",
          "candidateCount": 4,
          "semanticCandidateCount": 4,
          "topMemoryId": "p16-tag-title",
          "matchedTags": [
            "orm",
            "migration"
          ],
          "useRerank": true,
          "useGeodesicRerank": true,
          "useRerankPlus": true,
          "rrfAlpha": 0.6,
          "rerankMode": "local-rrf-geodesic",
          "source": "vcp-passive-adapter",
          "scopeApplied": false,
          "scopeWorkspacePresent": false
        }
      }
    },
    {
      "id": "group-tag-interleaves-semantic-buckets",
      "description": "TagMemo with Group(tag) should interleave semantic tag buckets before exhausting one dominant tag without overfitting same-tag sibling order.",
      "target": "process",
