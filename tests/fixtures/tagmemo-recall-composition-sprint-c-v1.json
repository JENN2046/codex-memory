{
  "schemaVersion": "tagmemo-recall-composition-fixture-v1",
  "scope": "Sprint C deterministic TagMemo bounded recall composition baseline",
  "boundaries": {
    "fixtureOnly": true,
    "providerApiCalls": 0,
    "bearerTokenUse": 0,
    "rawScan": false,
    "broadMemoryScan": false,
    "liveProof": false,
    "confirmedMutation": false,
    "persistentTagEnrichment": false,
    "publicMcpExpansion": false,
    "effectiveRecordMemoryWrites": 0,
    "completeV8Claimed": false,
    "productionReleaseCutoverReady": false
  },
  "expectedPublicTools": [
    "record_memory",
    "search_memory",
    "memory_overview",
    "audit_memory",
    "validate_memory",
    "tombstone_memory",
    "supersede_memory"
  ],
  "forbiddenFragments": [
    "cm1582-provider-endpoint",
    "cm1582-token-fragment",
    "cm1582-bearer-fragment",
    "cm1582-raw-memory-body",
    "A:/cm1582/must-not-leak"
  ],
  "cases": [
    {
      "id": "bounded-composition-ranks-relevant-candidate",
      "input": {
        "schemaVersion": "tagmemo-recall-composition-input-v1",
        "boundedQueryText": "route blocker proof",
        "recallIntent": "route_review",
        "seedMemoryId": "memory:cm1582:seed",
        "boundedMemoryText": "Explicit user instruction: preserve the route blocker proof receipt.",
        "metadataProjection": {
          "title": "Route blocker proof",
          "summary": "Decision, route, blocker, proof, and receipt evidence.",
          "sourceKind": "fixture"
        },
        "tagProjection": {
          "tags": [
            {
              "tagLabel": "route blocker",
              "tagSource": "explicit_record_tag",
              "confidenceScore": 0.94
            },
            {
              "tagLabel": "proof receipt",
              "tagSource": "operator_reviewed",
              "confidenceScore": 0.9
            }
          ]
        },
        "safeRecency": {
          "bucket": "recent",
          "sequence": 2
        },
        "safeEvidenceHints": [
          "explicit_user_instruction",
          "decision",
          "route",
          "blocker",
          "proof",
          "receipt"
        ],
        "candidates": [
          {
            "memoryId": "memory:cm1582:relevant",
            "boundedMemoryText": "Decision proof receipt for route blocker.",
            "metadataProjection": {
              "title": "Route blocker decision",
              "summary": "Proof receipt for the selected route.",
              "sourceKind": "fixture"
            },
            "tagProjection": {
              "tags": [
                {
                  "tagLabel": "route blocker",
                  "tagSource": "explicit_record_tag",
                  "confidenceScore": 0.95
                }
              ]
            },
            "safeRecency": {
              "bucket": "recent",
              "sequence": 2
            },
            "safeEvidenceHints": [
              "decision",
              "proof",
              "route"
            ]
          },
          {
            "memoryId": "memory:cm1582:less-relevant",
            "boundedMemoryText": "Temporary scratch status note.",
            "metadataProjection": {
              "title": "Scratch note",
              "summary": "Transient noise.",
              "sourceKind": "fixture"
            },
            "tagProjection": {
              "tags": [
                {
                  "tagLabel": "temporary status",
                  "tagSource": "derived_candidate",
                  "confidenceScore": 0.65
                }
              ]
            },
            "safeRecency": {
              "bucket": "stable",
              "sequence": 1
            },
            "safeEvidenceHints": [
              "temporary",
              "scratch"
            ]
          }
        ]
      },
      "expected": {
        "topMemoryId": "memory:cm1582:relevant",
        "requiredStages": [
          "query_expansion",
          "association_recall",
          "time_decay_scoring",
          "importance_scoring",
          "recall_ranking"
        ]
      }
    },
    {
      "id": "empty-candidates-low-disclosure",
      "input": {
        "schemaVersion": "tagmemo-recall-composition-input-v1",
        "boundedQueryText": "route",
        "recallIntent": "route_review",
        "seedMemoryId": "memory:cm1582:empty",
        "boundedMemoryText": "Route checkpoint.",
        "metadataProjection": {
          "title": "Route",
          "summary": "Route checkpoint.",
          "sourceKind": "fixture"
        },
        "tagProjection": {
          "tags": []
        },
        "safeRecency": {
          "bucket": "unknown",
          "sequence": 0
        },
        "safeEvidenceHints": [],
        "candidates": []
      },
      "expected": {
        "rejected": true,
        "reason": "empty_candidates"
      }
    },
    {
      "id": "forbidden-provider-token-raw-rejected",
      "input": {
        "schemaVersion": "tagmemo-recall-composition-input-v1",
        "boundedQueryText": "safe bounded query",
        "recallIntent": "general_recall",
        "seedMemoryId": "memory:cm1582:forbidden",
        "boundedMemoryText": "Bounded safe text.",
        "metadataProjection": {
          "title": "Forbidden fixture",
          "summary": "Should reject unsafe material.",
          "sourceKind": "fixture"
        },
        "tagProjection": {
          "tags": [
            {
              "tagLabel": "cm1582-provider-endpoint",
              "tagSource": "explicit_record_tag",
              "confidenceScore": 0.95
            }
          ]
        },
        "safeRecency": {
          "bucket": "recent",
          "sequence": 1
        },
        "safeEvidenceHints": [
          "cm1582-token-fragment"
        ],
        "candidates": [],
        "rawText": "cm1582-raw-memory-body",
        "authorization": "Bearer cm1582-bearer-fragment",
        "filePath": "A:/cm1582/must-not-leak"
      },
      "expected": {
        "rejected": true,
        "reason": "forbidden_raw_private_field"
      }
    }
  ]
