  "cases": [
    {
      "id": "bounded-runtime-recall-projection-ranks-relevant-candidate",
      "input": {
        "schemaVersion": "tagmemo-runtime-recall-projection-input-v1",
        "boundedQueryText": "route blocker proof",
        "recallIntent": "route_review",
        "seedProjection": {
          "memoryId": "memory:cm1587:seed",
          "boundedMemoryText": "Explicit user instruction: preserve the route blocker proof receipt.",
          "metadataProjection": {
            "title": "Route blocker proof",
            "summary": "Decision, route, blocker, proof, and receipt evidence.",
            "sourceKind": "fixture"
          },
          "tagProjection": {
            "tags": [
              {
                "tagLabel": "route blocker",
                "tagSource": "explicit_record_tag",
                "confidenceScore": 0.94
              },
              {
                "tagLabel": "proof receipt",
                "tagSource": "operator_reviewed",
                "confidenceScore": 0.9
              }
            ]
          },
          "safeRecency": {
            "bucket": "recent",
            "sequence": 2
          },
          "safeEvidenceHints": [
            "explicit_user_instruction",
            "decision",
            "route",
            "blocker",
            "proof",
            "receipt"
          ]
        },
        "candidates": [
          {
            "memoryId": "memory:cm1587:relevant",
            "boundedMemoryText": "Decision proof receipt for route blocker.",
            "metadataProjection": {
              "title": "Route blocker decision",
              "summary": "Proof receipt for the selected route.",
              "sourceKind": "fixture"
            },
            "tagProjection": {
              "tags": [
                {
                  "tagLabel": "route blocker",
                  "tagSource": "explicit_record_tag",
                  "confidenceScore": 0.95
                }
              ]
            },
            "safeRecency": {
              "bucket": "recent",
              "sequence": 2
            },
            "safeEvidenceHints": [
              "decision",
              "proof",
              "route"
            ]
          },
          {
            "memoryId": "memory:cm1587:less-relevant",
            "boundedMemoryText": "Temporary scratch status note.",
            "metadataProjection": {
              "title": "Scratch note",
              "summary": "Transient noise.",
              "sourceKind": "fixture"
            },
            "tagProjection": {
              "tags": [
                {
                  "tagLabel": "temporary status",
                  "tagSource": "derived_candidate",
                  "confidenceScore": 0.65
                }
              ]
            },
            "safeRecency": {
              "bucket": "stable",
              "sequence": 1
            },
            "safeEvidenceHints": [
              "temporary",
              "scratch"
            ]
          }
        ]
      },
      "expected": {
        "topMemoryId": "memory:cm1587:relevant",
        "projectionMode": "runtime_recall_noop",
        "publicResponse": false,
        "persisted": false,
        "mutated": false
      }
    },
    {
