{
  "schemaVersion": "v8-diagnostic-shape-v1",
  "phase": "P17.2-v8-diagnostic-fixture-shape-tests",
  "source": {
    "kind": "fixture-only",
    "synthetic": true,
    "realMemoryPreview": false
  },
  "safety": {
    "mode": "dry-run-shape-test",
    "mutated": false,
    "providerCalls": 0,
    "durableMemoryTouched": false,
    "realMemoryPreview": false,
    "redactionApplied": true,
    "rawWorkspaceIdExposed": false,
    "rawSecretExposed": false,
    "runtimeTuning": false,
    "publicMcpTools": [
      "record_memory",
      "search_memory",
      "memory_overview"
    ],
    "validateMemoryPublicTool": false
  },
  "reportShape": {
    "requiredTopLevelFields": [
      "mode",
      "destructive",
      "embeddingProfile",
      "query",
      "terrain",
      "residualPyramid",
      "tagMemo",
      "metaThinking",
      "geodesic"
    ],
    "embeddingProfileKeys": [
      "fingerprint",
      "version",
      "model",
      "dimensions",
      "ragProfile"
    ],
    "queryKeys": [
      "raw",
      "normalized",
      "passiveBlocks",
      "activeBlocks",
      "directives",
      "timeRanges"
    ],
    "terrainKeys": [
      "dominantAxes",
      "terrainBasis",
      "energySignature",
      "logicDepth",
      "resonance",
      "semanticWidth",
      "entropy"
    ],
    "residualPyramidKeys": [
      "levels",
      "totalExplainedEnergy",
      "features"
    ],
    "residualLevelKeys": [
      "level",
      "tags",
      "energyExplained",
      "residualEnergyRatio"
    ],
    "residualTagKeys": [
      "id",
      "name",
      "similarity",
      "contribution"
    ],
    "tagMemoKeys": [
      "coreTags",
      "mode",
      "dynamicTagWeight",
      "dynamicCoreWeight"
    ],
    "metaThinkingKeys": [
      "score",
      "threshold",
      "auto",
      "reasons"
    ],
    "geodesicKeys": [
      "requested",
      "alpha",
      "minGeoSamples",
      "willUse"
    ],
    "forbiddenKeys": [
      "hitRate",
      "qualityScore",
      "providerLatencyMs",
      "providerApiKey",
      "authorization",
      "cookie",
      "workspace_id",
      "envValue",
      "productionSnippet"
