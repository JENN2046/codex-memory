  },
  "cases": [
    {
      "id": "technical-migration-checkpoint",
      "query": "checkpoint migration audit ::TagMemo+1.5 ::Rerank+0.4 ::GeodesicRerank",
      "expected": {
        "mode": "v8-diagnose",
        "destructive": false,
        "normalized": "checkpoint migration audit",
        "geodesicRequested": true,
        "geodesicWillUse": true,
        "tagMemoMode": "explicit",
        "minCoreTagCount": 3,
        "minResidualLevelCount": 1
      }
    },
    {
      "id": "governance-policy-lifecycle",
      "query": "governed memory lifecycle scope policy supersede forget audit",
      "expected": {
        "mode": "v8-diagnose",
        "destructive": false,
        "normalized": "governed memory lifecycle scope policy supersede forget audit",
        "geodesicRequested": false,
        "geodesicWillUse": false,
        "tagMemoMode": "auto",
        "minCoreTagCount": 4,
        "minResidualLevelCount": 1
      }
    }
  ],
  "safeErrorCases": [
    {
      "id": "missing-query",
      "query": "",
      "expected": {
        "ok": false,
        "code": "QUERY_REQUIRED",
        "message": "v8-diagnose requires --query <text>",
        "destructive": false,
        "mutated": false,
        "providerCalls": 0,
        "durableMemoryTouched": false,
        "realMemoryPreview": false,
        "redactionApplied": true
      }
    }
  ],
  "forbiddenOutputClaims": [
    "raw secrets",
    "raw workspace identifiers",
    "provider keys",
    "authorization headers",
    "cookies",
    ".env values",
    "live provider latency claims when providerCalls is 0",
    "fake hitRate",
    "fake qualityScore",
    "production memory snippets"
  ]
}
