      "allowsDryRunOnlyWork": true,
      "allowsRealMemoryContentRead": false,
      "allowsPublicMcpExpansion": false
    },
    {
      "id": "A5-hard-stop",
      "description": "Requires separate explicit human approval before any execution.",
