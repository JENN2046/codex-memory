{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-memory.local/schemas/project-partition-registry-v1.schema.json",
  "title": "Project Partition Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "registryReference", "defaultPolicy", "projects"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "registryReference": { "const": "jenn-project-partition-registry-v1" },
    "defaultPolicy": { "const": "deny" },
    "projects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["projectId", "workspaceId", "clients"],
        "properties": {
          "projectId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
          "workspaceId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
          "clients": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9-]{0,29}$" }
          }
        }
      }
    }
  }
}
