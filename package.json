{
  "name": "codex-memory",
  "version": "0.1.0",
  "description": "Standalone Codex memory MCP server with diary-compatible storage and shadow indexing.",
  "private": true,
  "type": "commonjs",
  "bin": {
    "codex-memory": "./src/index.js",
    "codex-memory-http": "./src/http-index.js",
    "codex-memory-active-memory": "./src/cli/active-memory.js",
    "codex-memory-deepmemo": "./src/cli/deepmemo.js",
    "codex-memory-topicmemo": "./src/cli/topicmemo.js",
    "codex-memory-compare-vcp-active-memory": "./src/cli/compare-vcp-active-memory.js",
    "codex-memory-rollback-active-memory": "./src/cli/rollback-active-memory.js",
    "codex-memory-rebuild-shadow": "./src/cli/rebuild-shadow.js",
    "codex-memory-rebuild-profile": "./src/cli/rebuild-profile.js",
    "codex-memory-cleanup-legacy-chunks": "./src/cli/cleanup-legacy-chunks.js",
    "codex-memory-profile-health": "./src/cli/profile-health.js",
    "codex-memory-shadow-compare": "./src/cli/shadow-compare.js",
    "codex-memory-profile-gate": "./src/cli/profile-gate.js",
    "codex-memory-v8-diagnose": "./src/cli/v8-diagnose.js",
    "codex-memory-a5-approval-check": "./src/cli/a5-approval-check.js",
    "codex-memory-provider-smoke": "./src/cli/provider-smoke.js",
    "codex-memory-provider-benchmark": "./src/cli/provider-benchmark.js"
  },
  "scripts": {
    "start": "node ./src/index.js",
    "start:http": "node ./src/http-index.js",
    "start:http:ensure": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ensure-codex-memory-http.ps1",
    "start:http:install-task": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-codex-memory-http-task.ps1",
    "start:http:watchdog:once": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/watch-codex-memory-http.ps1 -Once",
    "start:http:watchdog:ensure": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ensure-codex-memory-http-watchdog.ps1",
    "start:http:watchdog:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-codex-memory-http-watchdog.ps1",
    "active-memory": "node ./src/cli/active-memory.js",
    "deepmemo": "node ./src/cli/deepmemo.js",
    "topicmemo": "node ./src/cli/topicmemo.js",
    "lightmemo": "node ./src/cli/lightmemo.js",
    "compare-active-memory": "node ./src/cli/compare-vcp-active-memory.js",
    "rollback-active-memory": "node ./src/cli/rollback-active-memory.js",
    "gate:mainline": "node ./src/cli/mainline-gate.js",
    "gate:mainline:strict": "node ./src/cli/mainline-gate.js strict",
    "gate:ci": "node ./src/cli/gate-ci.js",
    "observe:http": "node ./src/cli/http-observe.js",
    "dashboard": "node ./src/cli/dashboard.js",
    "governance:report": "node ./src/cli/governance-report.js",
    "rollback:mainline:plan": "node ./src/cli/mainline-rollback.js",
    "rebuild-shadow": "node ./src/cli/rebuild-shadow.js",
    "rebuild-profile": "node ./src/cli/rebuild-profile.js",
    "cleanup-legacy-chunks": "node ./src/cli/cleanup-legacy-chunks.js",
    "profile-health": "node ./src/cli/profile-health.js",
    "shadow-compare": "node ./src/cli/shadow-compare.js",
    "profile-gate": "node ./src/cli/profile-gate.js",
    "v8-diagnose": "node ./src/cli/v8-diagnose.js",
    "a5:approval-check": "node ./src/cli/a5-approval-check.js",
    "scope:acceptance": "node ./src/cli/scope-acceptance.js",
    "scope:backfill:dry-run": "node ./src/cli/scope-backfill-dry-run.js",
    "lifecycle:sqlite:dry-run": "node ./src/cli/lifecycle-sqlite-dry-run.js",
    "lifecycle:sqlite:migrate": "node ./src/cli/lifecycle-sqlite-migrate.js",
    "vcp-memory:mapping:dry-run": "node ./src/cli/vcp-memory-object-mapping-dry-run.js",
    "vcp-memory:migration-readiness": "node ./src/cli/vcp-memory-migration-readiness.js",
    "controlled-write:dry-run": "node ./src/cli/controlled-write-dry-run.js",
    "validate-memory": "node ./src/cli/validate-memory.js",
    "real-query-suite": "node ./src/cli/real-query-suite.js",
    "query:quality": "node ./src/cli/query-quality-report.js",
    "query:quality:temp-db": "node ./src/cli/query-quality-temp-db-gate.js",
    "provider-smoke": "node ./src/cli/provider-smoke.js",
    "provider-benchmark": "node ./src/cli/provider-benchmark.js",
    "test": "node ./src/cli/run-default-tests.js",
    "test:migration": "node ./src/cli/run-release-gate-tests.js migration",
    "test:parity": "node ./src/cli/run-release-gate-tests.js parity",
    "test:release-candidate": "node ./src/cli/run-release-gate-tests.js release-candidate",
    "test:hardening": "node --test --test-concurrency=1 tests/http-no-token-search-rejection.test.js tests/security-profile-config.test.js tests/external-provider-gate.test.js tests/stdio-message-size-limit.test.js tests/tool-argument-validator-limits.test.js tests/json-rpc-error-redaction.test.js && node --test tests/gate-ci-env-override-evidence.test.js",
    "test:provider": "node ./src/cli/run-provider-tests.js",
    "test:all": "npm test && npm run test:hardening"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
